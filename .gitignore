# === 自定义规则（在下方添加项目特定的忽略规则）===

# Python / skill runtime caches
__pycache__/
*.py[cod]
.pytest_cache/
.coverage

# AI / local execution artifacts
.parallel_vibe/

# Skill 运行时产物（计划与测试报告，不纳入版本控制）
# 仅为需要版本化的回归测试提供精确例外，避免把历史批次产物整目录放出来
skills/*/plans/
skills/*/tests/
!skills/dudu-vibe-config/tests/
skills/dudu-vibe-config/tests/*
!skills/dudu-vibe-config/tests/test_client_defaults.py


